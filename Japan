const ymdOf=d=>{const m=d.date.match(/(\d{4})\s*\/\s*(\d{1,2})\s*\/\s*(\d{1,2})/);return m[1]+m[2].padStart(2,'0')+m[3].padStart(2,'0');};
function parseTimes(ymd,t){
  if(!t)return null;
  const parts=t.replace(/[–—~〜]/g,'-').split('-').map(s=>s.trim()).filter(Boolean);
  const toDT=hm=>{const m=hm.match(/(\d{1,2}):(\d{2})/);return m?ymd+'T'+m[1].padStart(2,'0')+m[2]+'00':null;};
  const s=toDT(parts[0]); if(!s)return null;
  let e=parts[1]?toDT(parts[1]):null;
  if(!e){const mins=+s.slice(9,11)*60+ +s.slice(11,13)+90;
    if(mins>=1439){e=ymd+'T235900';}
    else e=ymd+'T'+String(Math.floor(mins/60)).padStart(2,'0')+String(mins%60).padStart(2,'0')+'00';}
  return {s,e};
}
function gcalUrl(ymd,i){
  const dt=parseTimes(ymd,i.t); if(!dt)return '';
  let det=i.n||''; if(i.u)det+=(det?'\n':'')+i.u;
  return 'https://calendar.google.com/calendar/render?action=TEMPLATE'
   +'&text='+encodeURIComponent(i.ti)+'&dates='+dt.s+'/'+dt.e+'&ctz=Asia/Tokyo'
   +'&details='+encodeURIComponent(det)+'&location='+encodeURIComponent(i.lo||i.ti);
}
const esc=s=>(s||'').replace(/\\/g,'\\\\').replace(/;/g,'\\;').replace(/,/g,'\\,').replace(/\n/g,'\\n');
function buildICS(){
  const L=['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//nishi-nihon//trip//ZH','CALSCALE:GREGORIAN','METHOD:PUBLISH',
    'BEGIN:VTIMEZONE','TZID:Asia/Tokyo','BEGIN:STANDARD','DTSTART:19700101T000000',
    'TZOFFSETFROM:+0900','TZOFFSETTO:+0900','TZNAME:JST','END:STANDARD','END:VTIMEZONE'];
  let uid=0;
  days.forEach(d=>{const ymd=ymdOf(d);d.items.forEach(i=>{
    const dt=parseTimes(ymd,i.t); if(!dt)return;
    let det=i.n||''; if(i.u)det+=(det?'\n':'')+i.u;
    L.push('BEGIN:VEVENT','UID:'+(++uid)+'-nishi-nihon','DTSTAMP:20260701T000000Z',
      'DTSTART;TZID=Asia/Tokyo:'+dt.s,'DTEND;TZID=Asia/Tokyo:'+dt.e,
      'SUMMARY:'+esc(i.ti),'LOCATION:'+esc(i.lo||''),'DESCRIPTION:'+esc(det),'END:VEVENT');
  });});
  L.push('END:VCALENDAR');
  return L.join('\r\n');
}

