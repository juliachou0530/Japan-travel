 </div>`;}).join('');

document.querySelectorAll('.memo textarea').forEach(ta=>{
  const k=ta.dataset.key;
  if(MEMO[k]){ta.value=MEMO[k];const d=ta.closest('.memo');d.classList.add('has');d.open=true;}
  ta.addEventListener('input',()=>{const d=ta.closest('.memo');
    if(ta.value.trim()){MEMO[k]=ta.value;d.classList.add('has');}else{delete MEMO[k];d.classList.remove('has');}
    saveMemo();});
});

